# ==================== SERVER ====================
PORT=3000
NODE_ENV=production

# ==================== AI SERVISLERI ====================
# Google Gemini API (birincil AI) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API (yedek AI) - https://console.anthropic.com/
# Opsiyonel: Gemini basarisiz olursa Claude kullanilir
CLAUDE_API_KEY=your_claude_api_key_here

# ==================== SUPABASE ====================
# Supabase proje ayarlarindan alinir - https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==================== ODEME (PayTR) ====================
# PayTR magaza panelinden alinir - https://www.paytr.com/
PAYTR_MERCHANT_ID=your_paytr_merchant_id
PAYTR_MERCHANT_KEY=your_paytr_merchant_key
PAYTR_MERCHANT_SALT=your_paytr_merchant_salt
# Test modu: 1 = test, 0 = canli odeme
PAYTR_TEST_MODE=1

# ==================== VIDEO ANALIZI (Pro Kullanicilar) ====================
# Video analizi ozelligi (true = aktif, false = kapali)
VIDEO_ANALYSIS_ENABLED=false
# yt-dlp binary yolu (varsayilan: yt-dlp)
YTDLP_PATH=yt-dlp
# Maksimum video suresi (saniye) - bu sureden uzun videolar indirilmez
MAX_VIDEO_DURATION_SECONDS=600

# ==================== UYGULAMA ====================
# Backend'in deploy edildigi URL (PayTR callback icin gerekli)
BACKEND_URL=https://your-app.onrender.com

# Admin kullanicilarin e-posta adresleri (virgul ile ayrilmis)
ADMIN_EMAILS=onurtncs@gmail.com,kozmikcase@gmail.com

# CORS icin izin verilen originler (virgul ile ayrilmis)
# Bos birakilirsa tum originler kabul edilir
ALLOWED_ORIGINS=
