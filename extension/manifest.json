{
  "manifest_version": 3,
  "name": "YouTube AI Prompt Analyzer",
  "version": "1.0",
  "description": "YouTube videolarını AI ile analiz eder ve içerik stratejileri oluşturur.",
  "permissions": [
    "contextMenus",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "http://localhost:3000/*",
    "https://*.onrender.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/watch*"
      ],
      "js": [
        "src/content/scraper.js"
      ]
    }
  ]
}